{
    "version": 1,
    "numberSystems": ["native", "sino", "digit"],
    "categories": [
      {
        "id": "date_time",
        "label": "Date & Time",
        "subcategories": [
          {
            "id": "time_of_day",
            "label": "Time of day",
            "variables": {
              "hour": { "type": "int", "min": 1, "max": 12, "system": "native" },
              "minute": { "type": "int", "min": 0, "max": 59, "system": "sino", "pad": 2 },
              "period": {
                "type": "choice",
                "values": [
                  { "en": "am", "ko": "오전" },
                  { "en": "pm", "ko": "오후" }
                ]
              }
            },
            "templates": [
              {
                "id": "time_hour_minute",
                "question": "{hour}:{minute} {period.en}",
                "answer": "{period.ko} {hour}시 {minute}분"
              },
              {
                "id": "time_half",
                "question": "{hour}:30 {period.en}",
                "answer": ["{period.ko} {hour}시 반", "{period.ko} {hour}시 삼십분"]
              }
            ]
          },
          {
            "id": "date_full",
            "label": "Full date",
            "variables": {
              "year": { "type": "int", "min": 1900, "max": 2035, "system": "sino" },
              "month": {
                "type": "choice",
                "values": [
                  { "en": "1", "ko": "일월" },
                  { "en": "2", "ko": "이월" },
                  { "en": "3", "ko": "삼월" },
                  { "en": "4", "ko": "사월" },
                  { "en": "5", "ko": "오월" },
                  { "en": "6", "ko": "유월" },
                  { "en": "7", "ko": "칠월" },
                  { "en": "8", "ko": "팔월" },
                  { "en": "9", "ko": "구월" },
                  { "en": "10", "ko": "시월" },
                  { "en": "11", "ko": "십일월" },
                  { "en": "12", "ko": "십이월" }
                ]
              },
              "day": { "type": "int", "min": 1, "max": 31, "system": "sino" },
              "weekday": {
                "type": "choice",
                "values": [
                  { "en": "Monday", "ko": "월요일" },
                  { "en": "Tuesday", "ko": "화요일" },
                  { "en": "Wednesday", "ko": "수요일" },
                  { "en": "Thursday", "ko": "목요일" },
                  { "en": "Friday", "ko": "금요일" },
                  { "en": "Saturday", "ko": "토요일" },
                  { "en": "Sunday", "ko": "일요일" }
                ]
              }
            },
            "templates": [
              {
                "id": "date_full_mdy",
                "question": "{month}/{day}/{year}",
                "answer": "{year} 년 {month} {day} 일"
              },
              {
                "id": "date_month_day",
                "question": "{month}/{day}",
                "answer": "{month} {day} 일"
              },
              {
                "id": "weekday_month_day",
                "question": "{weekday.en}, {month}/{day}",
                "answer": "{weekday.ko} {month} {day} 일"
              },
              {
                "id": "weekday_month_day_year",
                "question": "{weekday.en}, {month}/{day}/{year}",
                "answer": "{weekday.ko} {year} 년 {month} {day} 일"
              }
            ]
          }
        ]
      },
  
      {
        "id": "age",
        "label": "Age",
        "subcategories": [
          {
            "id": "standard_age",
            "label": "Age",
            "variables": {
              "age": { "type": "int", "min": 1, "max": 99, "system": "native" }
            },
            "templates": [
              {
                "id": "age_sal_se",
                "question": "{age} years old",
                "answer": ["{age} 살", "{age|sino} 세"]
              }
            ]
          },
          {
            "id": "birth_year",
            "label": "Birth year / 년생",
            "variables": {
              "year": { "type": "int", "min": 1900, "max": 2025, "system": "sino" },
              "shortYearDigit": { "type": "int", "min": 0, "max": 9, "system": "digit" }
            },
            "templates": [
              {
                "id": "birth_year_full",
                "question": "born in {year} (full year)",
                "answer": "{year} 년생"
              },
              {
                "id": "birth_year_short",
                "question": "born in {shortYearDigit}{shortYearDigit}",
                "answer": "{shortYearDigit}{shortYearDigit} 년생"
              }
            ]
          }
        ]
      },
  
      {
        "id": "won",
        "label": "Won",
        "variables": {
          "amount": {
            "type": "int",
            "min": 100,
            "step": 100,
            "system": "sino"
          }
        },
        "templates": [
          {
            "id": "won_amount",
            "question": "₩{amount}",
            "answer": "{amount} 원"
          }
        ]
      },
  
      {
        "id": "phone_numbers",
        "label": "Phone Numbers",
        "subcategories": [
          {
            "id": "korean_mobile",
            "label": "Korean phone number",
            "variables": {
              "prefix": { "type": "fixed", "value": "010", "system": "digit" },
              "middle": { "type": "digits", "length": 4, "system": "digit" },
              "last": { "type": "digits", "length": 4, "system": "digit" }
            },
            "templates": [
              {
                "id": "korean_mobile",
                "question": "{prefix}-{middle}-{last}",
                "answer": "{prefix} {middle} {last}"
              }
            ]
          },
          {
            "id": "western_phone",
            "label": "Western phone number",
            "variables": {
              "area": { "type": "digits", "length": 3, "system": "digit" },
              "middle": { "type": "digits", "length": 3, "system": "digit" },
              "last": { "type": "digits", "length": 4, "system": "digit" }
            },
            "templates": [
              {
                "id": "western_phone",
                "question": "{area}-{middle}-{last}",
                "answer": "{area} {middle} {last}"
              }
            ]
          }
        ]
      },
